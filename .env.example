# ---------------------------------------------------------------------------
# LedgerLens — environment variables (SERVER-ONLY)
#
# Copy this file to `.env.local` for local dev, and add the same keys in
# Vercel → Project Settings → Environment Variables for production.
#
# IMPORTANT: none of these are prefixed with NEXT_PUBLIC_. They must NEVER be
# exposed to the browser. They are read only inside the /api/categorize route.
# ---------------------------------------------------------------------------

# Which LLM provider to use for the fallback categorizer: "groq" or "gemini".
LLM_PROVIDER=groq

# --- Groq (OpenAI-compatible) -----------------------------------------------
# Get a free key at https://console.groq.com
GROQ_API_KEY=
# Confirm the current model id at console.groq.com (Groq rotates its catalog).
# Quality:  llama-3.3-70b-versatile
# Faster:   llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ----------------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Free tier is Flash / Flash-Lite only (Pro became paid in April 2026).
# Confirm the current model id in Google AI Studio.
# e.g. gemini-2.5-flash, gemini-3-flash, gemini-3.1-flash-lite
GEMINI_MODEL=gemini-2.5-flash
